# Proxmox Backup Server configuration
# Format: user@realm!tokenname@server:datastore
PBS_REPOSITORY="AWSbackup@pbs!AWSClients@10.170.144.254:BCK01_scsi1"
PBS_PASSWORD="737d5ef0-4790-41dc-93ea-06cdc9bd27fc"
PBS_FINGERPRINT="b1:ac:bc:f3:6f:79:47:bd:26:60:f5:86:a5:46:bf:27:cc:3c:12:e7:4e:cd:7a:96:81:63:72:54:cf:11:ab:dc"

# Backup targets (space-separated label:path pairs for proxmox-backup-client)
PBS_BACKUP_TARGETS="home.pxar:/home/commsadmin mnt.pxar:/mnt docker-volumes.pxar:/var/lib/docker/volumes"

# Encryption at rest (AES-256-GCM, client-side)
# Path to encryption key file (generated by init.sh --with-pbs if missing)
PBS_KEYFILE="/etc/pbs/encryption-key.json"
# Password protecting the encryption key (used non-interactively via PBS_ENCRYPTION_PASSWORD)
# Set this BEFORE running init.sh, or regenerate the key afterward
PBS_ENCRYPTION_PASSWORD="CHANGE-ME-to-a-strong-passphrase"

#!/bin/bash

log()      { echo -e "\033[1;34m[INFO]\033[0m $*"; }
fail()     { echo -e "\033[1;31m[ERROR]\033[0m $*" >&2; exit 1; }
complete() { echo -e "\033[1;32m[COMPLETE]\033[0m $*"; }
warn()     { echo -e "\033[1;33m[WARNING]\033[0m $*"; }

JOB="update-commands-base"
DIR1="/opt/ubuntu-autoconfig"
CONFIG_SOURCE="$DIR1/commands"
CONFIG_DESTINATION="/usr/local/bin"
LIB_SOURCE="$CONFIG_SOURCE/lib"
LIB_DESTINATION="$CONFIG_DESTINATION/lib"

# Elevate once (one sudo for everything)
if [ "$EUID" -ne 0 ]; then
  exec sudo -E bash "$0" "$@"
fi

set -euo pipefail
trap 'fail "Script failed at line $LINENO (exit $?)"' ERR

log "Starting '$JOB'"

# Change to repo directory
cd "$DIR1" || fail "Failed to change directory to $DIR1"

# Mark $DIR1 as a safe Git directory for sudo usage
log "Checking if $DIR1 is already a safe Git directory..."

if sudo -E git config --global --get-all safe.directory | grep -qx "$DIR1"; then
    log "$DIR1 is already marked as a safe Git directory. Skipping."
else
    log "Marking $DIR1 as a safe Git directory..."
    if sudo -E git config --global --add safe.directory "$DIR1"; then
        # Verify it was added
        if sudo -E git config --global --get-all safe.directory | grep -qx "$DIR1"; then
            complete "$DIR1 has been added to safe Git directories."
        else
            fail "Tried to add $DIR1, but it is NOT listed as a safe Git directory!"
        fi
    else
        fail "Failed to add $DIR1 as a safe Git directory (git config command failed)."
    fi
fi

log "Resetting any local changes..."
sudo -E git reset --hard HEAD
# Note: git clean is disabled - can delete important untracked files if .gitignore is incorrect
# sudo -E git clean -fd

# Detect current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if ! [[ "$BRANCH" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
    fail "Invalid branch name detected: $BRANCH"
fi
log "Detected current Git branch: '$BRANCH'"

# Pull latest changes from the detected branch
log "Pulling latest changes from Git..."
sudo HOME=/home/commsadmin -E git pull origin "$BRANCH" || fail "Git pull failed for $DIR1"

log "Making all .sh files executable..."
find "$DIR1" -path "$DIR1/lost+found" -prune -o -type f -name "*.sh" -exec sudo chmod +x {} +

# Deploy shared libraries
log "Deploying shared libraries to $LIB_DESTINATION..."
sudo mkdir -p "$LIB_DESTINATION"
if [ -d "$LIB_SOURCE" ]; then
    sudo cp -r "$LIB_SOURCE"/* "$LIB_DESTINATION/"
    sudo chmod +x "$LIB_DESTINATION"/*.sh
    complete "Shared libraries deployed"
else
    warn "Library source directory $LIB_SOURCE not found, skipping lib deployment"
fi

# List of command scripts to deploy
SCRIPT_LIST=(
    update-commands-base
    system-update-with-reboot
    system-update-no-reboot
    pbs-backup
    pbs-restore
    pbs-update
    pbs-setup
)

for script in "${SCRIPT_LIST[@]}"; do
    SRC="$CONFIG_SOURCE/$script"
    DST="$CONFIG_DESTINATION/$script"

    if [ -f "$DST" ]; then
        sudo cp "$DST" "$DST.bak.$(date +%Y%m%d%H%M%S)" || fail "Failed to backup old $script"
        log "Backed up existing $script"

        # Keep only the most recent .bak file for this script
        bak_files=($(ls -1t "$DST.bak."* 2>/dev/null))
        if (( ${#bak_files[@]} > 1 )); then
            for old_bak in "${bak_files[@]:1}"; do
                sudo rm -f "$old_bak" && log "Removed old backup $old_bak"
            done
        fi
    fi

    log "Copying $script to $CONFIG_DESTINATION..."
    if [ -f "$SRC" ]; then
        sudo cp "$SRC" "$DST" || fail "Failed to copy new $script"
        sudo chmod +x "$DST" || fail "Failed to make $script executable"
        log "$script installed and made executable."
    else
        fail "Source script $SRC does not exist."
    fi
done

complete "$JOB"

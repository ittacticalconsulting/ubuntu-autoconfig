#!/bin/bash

log()      { echo -e "\033[1;34m[INFO]\033[0m $*"; }
fail()     { echo -e "\033[1;31m[ERROR]\033[0m $*" >&2; exit 1; }
complete() { echo -e "\033[1;32m[COMPLETE]\033[0m $*"; }
warn()     { echo -e "\033[1;33m[WARNING]\033[0m $*"; }

JOB="pbs-restore"

usage() {
  cat <<'USAGE'
Usage: pbs-restore [OPTIONS]

Restore backups from Proxmox Backup Server.

Modes:
  (no args)                  Interactive — list snapshots for this host, pick one, restore all archives
  --list                     List available snapshots for this host and exit
  --snapshot <snap>          Restore all archives from the specified snapshot
  --snapshot <snap> --archive <name> --target <path>
                             Restore a single archive to a specific directory

Options:
  --list                     List snapshots for this host and exit
  --snapshot <snap>          Snapshot to restore (e.g., host/myserver01/2024-01-15T02:00:00Z)
  --archive <name>           Restore only this archive (e.g., home.pxar). Requires --snapshot
  --target <path>            Restore to this directory (default: /mnt/restore/<timestamp>)
  --debug                    Show raw PBS client output and enable shell tracing
  --help                     Show this help and exit

Examples:
  sudo pbs-restore --list
  sudo pbs-restore
  sudo pbs-restore --snapshot host/myserver01/2024-01-15T02:00:00Z
  sudo pbs-restore --snapshot host/myserver01/2024-01-15T02:00:00Z \
    --archive home.pxar --target /tmp/restore-home
USAGE
  exit 0
}

# Elevate once (one sudo for everything)
if [ "$EUID" -ne 0 ]; then
  exec sudo -E bash "$0" "$@"
fi

set -euo pipefail
trap 'fail "Script failed at line $LINENO (exit $?)"' ERR

# Parse arguments
MODE="interactive"
SNAPSHOT=""
ARCHIVE=""
TARGET=""
DEBUG=0

while [[ ${1:-} ]]; do
  case "$1" in
    --list)      MODE="list" ;;
    --snapshot)  MODE="direct"; shift; SNAPSHOT="${1:-}"; [ -z "$SNAPSHOT" ] && fail "--snapshot requires a value" ;;
    --archive)   shift; ARCHIVE="${1:-}"; [ -z "$ARCHIVE" ] && fail "--archive requires a value" ;;
    --target)    shift; TARGET="${1:-}"; [ -z "$TARGET" ] && fail "--target requires a value" ;;
    --debug)     DEBUG=1; set -x; log "Debug mode enabled." ;;
    --help|-h)   usage ;;
    *)           fail "Unknown option: $1. Use --help for usage." ;;
  esac
  shift
done

# Stderr redirect: suppress in normal mode, show in debug mode
if [ "$DEBUG" -eq 1 ]; then
  STDERR_REDIR="/dev/stderr"
else
  STDERR_REDIR="/dev/null"
fi

# Validate flag combinations
if [ -n "$ARCHIVE" ] && [ -z "$SNAPSHOT" ]; then
  fail "--archive requires --snapshot"
fi

PBS_ENV_FILE="/etc/pbs-backup.env"

if [ ! -f "$PBS_ENV_FILE" ]; then
  fail "PBS config not found at $PBS_ENV_FILE. Run init.sh --with-pbs to deploy it."
fi

# Source env file with decryption support
if [ -f /usr/local/lib/ubuntu-base/pbs-crypt.sh ]; then
  # shellcheck source=/dev/null
  source /usr/local/lib/ubuntu-base/pbs-crypt.sh
  pbs_source_env "$PBS_ENV_FILE"
else
  # shellcheck source=/dev/null
  source "$PBS_ENV_FILE"
fi

# Validate required variables
if [ -z "${PBS_REPOSITORY:-}" ]; then
  fail "PBS_REPOSITORY is not set in $PBS_ENV_FILE"
fi
if [ -z "${PBS_PASSWORD:-}" ] || [ "$PBS_PASSWORD" = "YOUR-API-TOKEN-SECRET-HERE" ]; then
  fail "PBS_PASSWORD is not configured in $PBS_ENV_FILE"
fi

# Export for proxmox-backup-client
export PBS_REPOSITORY
export PBS_PASSWORD
if [ -n "${PBS_FINGERPRINT:-}" ]; then
  export PBS_FINGERPRINT
fi

# Encryption key support
KEYFILE_ARGS=()
if [ -n "${PBS_KEYFILE:-}" ] && [ -f "$PBS_KEYFILE" ]; then
  log "Encryption key found (keyfile: $PBS_KEYFILE)"
  KEYFILE_ARGS=(--keyfile "$PBS_KEYFILE")
  if [ -n "${PBS_ENCRYPTION_PASSWORD:-}" ] && [ "$PBS_ENCRYPTION_PASSWORD" != "CHANGE-ME-to-a-strong-passphrase" ]; then
    export PBS_ENCRYPTION_PASSWORD
  fi
elif [ -n "${PBS_KEYFILE:-}" ] && [ ! -f "$PBS_KEYFILE" ]; then
  warn "PBS_KEYFILE set to $PBS_KEYFILE but file does not exist."
  warn "Restoring encrypted backups will FAIL without the encryption key."
fi

CURRENT_HOST="$(hostname)"

# List snapshots filtered by current hostname
list_snapshots() {
  log "Listing snapshots for host: $CURRENT_HOST"
  log "PBS server: $PBS_REPOSITORY"
  proxmox-backup-client snapshot list --output-format json-pretty 2>"$STDERR_REDIR" \
    | grep -o '"backup-id"[[:space:]]*:[[:space:]]*"[^"]*"' \
    | sed 's/"backup-id"[[:space:]]*:[[:space:]]*"//;s/"$//' \
    | sort -u \
    || true
}

# Get full snapshot paths (backup-type/backup-id/backup-time) for current host
# Uses grep -oE to extract paths regardless of text table formatting (bordered vs plain)
get_snapshots_for_host() {
  local raw
  raw="$(proxmox-backup-client snapshot list --output-format text 2>"$STDERR_REDIR")" || true
  if [ "$DEBUG" -eq 1 ]; then
    log "Raw snapshot list output:"
    echo "$raw"
    log "Filtering for: host/${CURRENT_HOST}/"
  fi
  echo "$raw" \
    | grep -oE "host/${CURRENT_HOST}/[^[:space:]|]+" \
    | sort -t/ -k3 -r \
    || true
}

# List archives in a snapshot
# Uses grep -oE to extract archive names regardless of text table formatting
get_snapshot_archives() {
  local snap="$1"
  local raw
  raw="$(proxmox-backup-client snapshot files "$snap" --output-format text 2>"$STDERR_REDIR")" || true
  if [ "$DEBUG" -eq 1 ]; then
    log "Raw snapshot files output for $snap:"
    echo "$raw"
  fi
  echo "$raw" \
    | grep -oE '[^[:space:]|]+\.(pxar|img)' \
    || true
}

# Restore a single archive from a snapshot to a target directory
restore_archive() {
  local snap="$1"
  local archive="$2"
  local target="$3"

  mkdir -p "$target"

  if [[ "$archive" == *.pxar ]]; then
    log "Restoring $archive from $snap to $target"
    proxmox-backup-client restore "$snap" "$archive" "$target" "${KEYFILE_ARGS[@]}"
  elif [[ "$archive" == *.img ]]; then
    log "Restoring $archive from $snap to $target/$archive"
    proxmox-backup-client restore "$snap" "$archive" "$target/$archive" "${KEYFILE_ARGS[@]}"
  else
    warn "Unknown archive type: $archive — skipping"
    return 1
  fi
}

# Restore all archives from a snapshot
restore_all_archives() {
  local snap="$1"
  local base_target="$2"

  local archives
  archives="$(get_snapshot_archives "$snap")"

  if [ -z "$archives" ]; then
    fail "No archives found in snapshot $snap"
  fi

  log "Archives found in $snap:"
  echo "$archives" | while read -r a; do echo "  - $a"; done

  local count=0
  while read -r archive; do
    [ -z "$archive" ] && continue
    local archive_name="${archive%.pxar}"
    archive_name="${archive_name%.img}"
    local target="$base_target/$archive_name"
    restore_archive "$snap" "$archive" "$target" && ((count++)) || warn "Failed to restore $archive"
  done <<< "$archives"

  log "Restored $count archive(s) to $base_target"
}

# --- Main logic ---

case "$MODE" in
  list)
    log "Starting '$JOB' (list mode)"
    snapshots="$(get_snapshots_for_host)"
    if [ -z "$snapshots" ]; then
      warn "No snapshots found for host '$CURRENT_HOST'."
      warn "If the hostname changed, use: proxmox-backup-client snapshot list"
      exit 0
    fi
    echo ""
    log "Snapshots for host '$CURRENT_HOST':"
    echo "$snapshots"
    echo ""
    ;;

  interactive)
    log "Starting '$JOB' (interactive mode)"
    log "PBS server: $PBS_REPOSITORY"
    log "Looking up snapshots for host: $CURRENT_HOST"

    snapshots="$(get_snapshots_for_host)"
    if [ -z "$snapshots" ]; then
      fail "No snapshots found for host '$CURRENT_HOST'. If the hostname changed, use --snapshot with the full path."
    fi

    # Build numbered menu
    mapfile -t snap_array <<< "$snapshots"
    echo ""
    log "Available snapshots for '$CURRENT_HOST':"
    for i in "${!snap_array[@]}"; do
      printf "  %d) %s\n" "$((i + 1))" "${snap_array[$i]}"
    done
    echo ""

    # Prompt user
    local_choice=""
    while true; do
      read -rp "Select snapshot number to restore [1-${#snap_array[@]}] (or 'q' to quit): " local_choice
      if [ "$local_choice" = "q" ] || [ "$local_choice" = "Q" ]; then
        log "Restore cancelled."
        exit 0
      fi
      if [[ "$local_choice" =~ ^[0-9]+$ ]] && [ "$local_choice" -ge 1 ] && [ "$local_choice" -le "${#snap_array[@]}" ]; then
        break
      fi
      warn "Invalid selection. Enter a number between 1 and ${#snap_array[@]}."
    done

    SNAPSHOT="${snap_array[$((local_choice - 1))]}"
    log "Selected: $SNAPSHOT"

    # Set default target
    if [ -z "$TARGET" ]; then
      TARGET="/mnt/restore/$(date +%Y%m%d-%H%M%S)"
    fi

    log "Restoring all archives to $TARGET"
    restore_all_archives "$SNAPSHOT" "$TARGET"
    complete "$JOB — restored $SNAPSHOT to $TARGET"
    ;;

  direct)
    # Direct snapshot mode (--snapshot provided)
    log "Starting '$JOB'"
    log "PBS server: $PBS_REPOSITORY"

    if [ -z "$SNAPSHOT" ]; then
      fail "No snapshot specified. Use --snapshot or run without flags for interactive mode."
    fi

    if [ -z "$TARGET" ]; then
      TARGET="/mnt/restore/$(date +%Y%m%d-%H%M%S)"
    fi

    if [ -n "$ARCHIVE" ]; then
      # Single archive restore
      log "Restoring archive '$ARCHIVE' from $SNAPSHOT to $TARGET"
      restore_archive "$SNAPSHOT" "$ARCHIVE" "$TARGET"
      complete "$JOB — restored $ARCHIVE from $SNAPSHOT to $TARGET"
    else
      # Full snapshot restore
      log "Restoring all archives from $SNAPSHOT to $TARGET"
      restore_all_archives "$SNAPSHOT" "$TARGET"
      complete "$JOB — restored $SNAPSHOT to $TARGET"
    fi
    ;;
esac

#!/bin/bash
# init-autoconfig-update - pull latest autoconfig repo and re-run init (unattended, no reboot)

log()      { echo -e "\033[1;34m[INFO]\033[0m $*"; }
fail()     { echo -e "\033[1;31m[ERROR]\033[0m $*" >&2; exit 1; }
complete() { echo -e "\033[1;32m[COMPLETE]\033[0m $*"; }
warn()     { echo -e "\033[1;33m[WARNING]\033[0m $*"; }

JOB="init-autoconfig-update"
DIR="/opt/ubuntu-autoconfig"

if [ "$EUID" -ne 0 ]; then
  exec sudo -E bash "$0" "$@"
fi

set -euo pipefail
trap 'fail "Script failed at line $LINENO (exit $?)"' ERR

usage() {
  cat <<EOF
Usage: init-autoconfig-update [OPTIONS]

Pull the latest ubuntu-autoconfig repo and re-run init.sh in unattended
mode without reboot. This is a one-command way to update all base configs,
packages, and commands on a host.

Options:
  --debug    Enable bash debug tracing (set -x)
  -h, --help Show this help message
EOF
  exit 0
}

DEBUG_FLAG=""

for arg in "$@"; do
  case "$arg" in
    -h|--help) usage ;;
    --debug)   DEBUG_FLAG="--debug"; set -x; log "Debug mode enabled." ;;
    *)         fail "Unknown option: $arg. Use --help for usage." ;;
  esac
done

# --- 1. Ensure safe.directory for sudo git ---
if git config --global --get-all safe.directory 2>/dev/null | grep -qx "$DIR"; then
  log "$DIR is already a safe Git directory."
else
  log "Marking $DIR as a safe Git directory..."
  git config --global --add safe.directory "$DIR"
fi

# --- 2. Pull latest code ---
cd "$DIR" || fail "Failed to change directory to $DIR"

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if ! [[ "$BRANCH" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
  fail "Invalid branch name detected: $BRANCH"
fi
log "Branch: $BRANCH"

log "Resetting any local changes..."
git reset --hard HEAD

log "Pulling latest changes..."
HOME=/home/kynetra git pull origin "$BRANCH" || fail "Git pull failed for $DIR"

log "Making all .sh files executable..."
find "$DIR" -path "$DIR/lost+found" -prune -o -type f -name "*.sh" -exec chmod +x {} +

# --- 3. Run init.sh unattended, no reboot ---
log "Running init.sh --unattended --no-reboot $DEBUG_FLAG"
bash "$DIR/scripts/init.sh" --unattended --no-reboot $DEBUG_FLAG

complete "$JOB — autoconfig updated and init completed."
